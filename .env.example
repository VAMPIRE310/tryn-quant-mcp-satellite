# MCP Satellite Environment Variables

# MCP Server Target Configuration
# ================================

# Option 1: Use Railway backend (recommended for production)
# Set to 'true' to route MCP requests to Railway
USE_RAILWAY=false
RAILWAY_MCP_URL=https://your-railway-app.up.railway.app

# Option 2: Use OpenClaw tunnel (connects to user's PC)
# This is the Cloudflare tunnel URL from your local OpenClaw gateway
OPENCLAW_TUNNEL_URL=https://offering-soil-interviews-estimation.trycloudflare.com

# Option 3: Direct OpenClaw gateway (local development only)
OPENCLAW_GATEWAY_URL=http://localhost:18789

# Authentication
# ==============
# Set this to protect your MCP endpoint
# GitHub Copilot will send: Authorization: Bearer <this_token>
MCP_AUTH_TOKEN=your-secure-random-token-here

# Security Notes:
# - Change MCP_AUTH_TOKEN to a secure random string
# - In production, use Railway (more stable than Vercel for long connections)
# - The tunnel URL connects to your PC - keep it secret
